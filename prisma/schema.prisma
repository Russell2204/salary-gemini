datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  name      String?
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  jobs      Job[]
  expenses  Expense[]
}

model Job {
  id            String   @id @default(uuid())
  title         String   // Название работы / источника дохода
  monthlySalary Float    // Сумма дохода в месяц
  isActive      Boolean  @default(true) // Участвует ли в общем расчете
  createdAt     DateTime @default(now())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Expense {
  id          String   @id @default(uuid())
  amount      Float    // Сумма расхода
  category    String   // Категория
  description String?  // Комментарий
  date        DateTime @default(now()) // Дата расхода
  createdAt   DateTime @default(now())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
